#!/usr/bin/env bash
# Evicts loaded Ollama models from VRAM when a Steam game starts.
# Runs as a systemd user service — no root required.
set -uo pipefail

OLLAMA_URL="http://localhost:11434"
POLL_INTERVAL=2   # seconds between checks
game_was_running=false

log() { echo "[ollama-game-watcher] $*"; }

# Query /api/ps and print one model name per line.
loaded_models() {
    curl -sf "$OLLAMA_URL/api/ps" \
        | python3 -c "
import json, sys
data = json.load(sys.stdin)
for m in data.get('models', []):
    print(m['name'])
" 2>/dev/null || true
}

# Set keep_alive=0 on a loaded model, which makes Ollama evict it immediately.
unload_model() {
    local name="$1"
    curl -sf "$OLLAMA_URL/api/generate" \
        -H "Content-Type: application/json" \
        -d "{\"model\":\"$name\",\"keep_alive\":0,\"stream\":false}" \
        -o /dev/null || true
}

unload_all() {
    local models
    models=$(loaded_models)
    [[ -z "$models" ]] && { log "No models loaded — nothing to evict."; return; }

    log "Game started — evicting from VRAM: $(echo "$models" | paste -sd ', ')"
    while IFS= read -r name; do
        unload_model "$name"
        log "  evicted: $name"
    done <<< "$models"
}

is_game_running() {
    # Steam's reaper binary is launched as:
    #   reaper SteamLaunch AppId=XXXXX -- /path/to/game
    # This process exists only while a game is running, not while Steam is
    # merely open. The steamwebhelper pressure-vessel processes never carry
    # this flag so they don't produce false positives.
    pgrep -f "SteamLaunch AppId" > /dev/null 2>&1
}

log "Watching for Steam game launches (polling every ${POLL_INTERVAL}s)..."

while true; do
    if is_game_running; then
        if [[ "$game_was_running" == "false" ]]; then
            game_was_running=true
            unload_all
        fi
    else
        if [[ "$game_was_running" == "true" ]]; then
            log "Game exited — Ollama will load models on next request."
        fi
        game_was_running=false
    fi
    sleep "$POLL_INTERVAL"
done
